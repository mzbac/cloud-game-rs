# Rust-only production stack
COMPOSE_PROFILES=

# Images / tags
SIGNAL_IMAGE=cloud-arcade/signal:latest
WORKER_IMAGE=cloud-arcade/worker:latest
PORTAL_IMAGE=cloud-arcade/portal:latest

# Docker build inputs (used by docker compose + container-stack)
SIGNAL_DOCKERFILE=deploy/dockerfiles/signal.Dockerfile
SIGNAL_BUILD_CONTEXT=..
SIGNAL_SERVICE_DIR=arcade-signal
SIGNAL_SERVICE_BINARY=signal
SIGNAL_HOST_PORT=8000

# Container runtime target (apple/container)
CONTAINER_PLATFORM=linux/amd64
CONTAINER_NETWORK=cloud-arcade
CONTAINER_NETWORK_SUBNET=192.168.200.0/24
CONTAINER_NAME_PREFIX=

WORKER_DOCKERFILE=deploy/dockerfiles/worker.Dockerfile
WORKER_BUILD_CONTEXT=..
WORKER_SERVICE_DIR=arcade-worker
WORKER_SERVICE_BINARY=worker

# Ports
SIGNAL_PORT=8000
PORTAL_PORT=8080

# Endpoints and health
SIGNAL_ADDR=:8000
WORKER_HEALTH_ADDR=:8081
WORKER_HEALTH_HOST_PORT=8081
RUN_WS_SMOKE_CHECK=1
WS_SMOKE_CHECK_HOST=127.0.0.1
WS_SMOKE_CHECK_PORT=8000
WS_SMOKE_CHECK_PATH=/ws
WS_SMOKE_CHECK_TIMEOUT=8
SIGNAL_BROWSER_PATH=/ws
SIGNAL_WORKER_PATH=/wws
REACT_APP_SIGNALING_URL=/ws
REACT_APP_SIGNALING_TOKEN=
# Worker networking (used by deploy/container-stack.sh; docker-compose uses bridge networking):
# - bridge (default): WebRTC candidates may be unreachable from LAN clients (black stream / disconnects)
# - host: recommended for LAN stability (worker can advertise 192.168.x.x host candidates)
WORKER_NETWORK_MODE=host
WORKER_SIGNAL_URL=
WORKER_SIGNAL_TOKEN=
PORTAL_SIGNAL_BACKEND=signal

# Optional websocket access controls
SIGNAL_AUTH_TOKEN=
SIGNAL_ALLOWED_ORIGINS=

# Worker games:
# - Set WORKER_GAMES (comma-separated) to launch one worker per game (multiple rooms in the portal).
# - Defaults to auto discovery when unset.
# - Values can be absolute paths or relative paths under your configured asset root.
# WORKER_GAMES=assets/games/game1.zip,assets/games/game2.zip,assets/games/game3.zip
# WORKER_DEFAULT_GAME=assets/games/example.zip

# Runtime tuning
SIGNAL_LOG_LEVEL=info
WORKER_LOG_LEVEL=info
