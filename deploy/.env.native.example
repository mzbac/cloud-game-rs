# Native stack runner configuration (non-container mode)
# This file is safe to copy to .env.production.local and customize.

# Signal
SIGNAL_SERVICE_DIR=arcade-signal
SIGNAL_SERVICE_BINARY=signal
SIGNAL_ADDR=:8000
SIGNAL_HOST_PORT=8000
SIGNAL_LOG_LEVEL=info
SIGNAL_BROWSER_PATH=/ws
SIGNAL_WORKER_PATH=/wws

# Worker
WORKER_SERVICE_DIR=arcade-worker
WORKER_SERVICE_BINARY=worker
WORKER_HEALTH_ADDR=:8081
WORKER_HEALTH_HOST_PORT=8081
WORKER_LOG_LEVEL=info
WORKER_SIGNAL_URL=ws://127.0.0.1:8000/wws

# Portal
PORTAL_PORT=8080
PORTAL_BUILD_DIR=./arcade-portal/build
REACT_APP_SIGNALING_URL=/ws
PORTAL_PUBLIC_HOST=
PORTAL_PUBLIC_PORT=

# Health + startup behavior
PORTAL_HEALTH_PATH=/healthz
WORKER_STARTUP_WAIT_SECONDS=120

# To run without reverse proxy, set PORTAL signalling URL to ws://host:port/ws
# and pass --skip-proxy. This may require rebuilding portal artifacts.
